{
  "use_case_id": "pl-aip-uplift",
  "use_case_name": "Personal Loan - AIP Uplift",
  "campaign_start_date": "2025-04-01",
  "campaign_end_date": "2025-05-31",
  "campaign_status": "ACTIVE",
  "version": "2.0",
  "architecture": "feature-based",
  "description": "Feature-based contextual bandit for optimizing PL campaign actions. Dimensions defined as feature sets, not static options.",
  "dimensions": {
    "frequency": {
      "type": "numeric",
      "description": "Campaign frequency per user per rolling 7-day window",
      "features": {
        "count": {
          "type": "numeric",
          "description": "Number of campaigns to send per period",
          "values": [1, 2, 3, 7],
          "unit": "campaigns",
          "labels": {
            "1": "FR001 - 1x per week",
            "2": "FR002 - 2x per week",
            "3": "FR003 - 3x per week",
            "7": "FR004 - Daily"
          }
        },
        "period_days": {
          "type": "numeric",
          "description": "Rolling window period",
          "values": [7],
          "unit": "days"
        }
      }
    },
    "channel": {
      "type": "categorical",
      "description": "Communication channel for campaign delivery",
      "features": {
        "cost_per_send": {
          "type": "numeric",
          "description": "Cost to send one campaign via this channel",
          "values": [0.39, 0.12, 0.25, 0.03, 0.05],
          "unit": "INR",
          "labels": {
            "0.39": "CH001 - WhatsApp (₹0.39)",
            "0.12": "CH002 - SMS (₹0.12)",
            "0.25": "CH003 - RCS (₹0.25)",
            "0.03": "CH004 - Push (₹0.03)",
            "0.05": "CH005 - Email (₹0.05)"
          }
        },
        "channel_type": {
          "type": "categorical",
          "description": "Type of communication channel",
          "values": ["WhatsApp", "SMS", "RCS", "Push", "Email"],
          "labels": {
            "WhatsApp": "CH001 - WhatsApp",
            "SMS": "CH002 - SMS",
            "RCS": "CH003 - RCS",
            "Push": "CH004 - Push",
            "Email": "CH005 - Email"
          }
        },
        "delivery_latency": {
          "type": "numeric",
          "description": "Expected delivery latency in minutes",
          "values": [1, 3, 5, 5, 30],
          "unit": "minutes",
          "notes": "WhatsApp=1, SMS=3, RCS=5, Push=5, Email=30"
        },
        "open_rate_baseline": {
          "type": "numeric",
          "description": "Historical average open rate for this channel",
          "values": [0.45, 0.25, 0.35, 0.20, 0.15],
          "unit": "fraction",
          "notes": "WhatsApp=45%, SMS=25%, RCS=35%, Push=20%, Email=15%"
        }
      }
    },
    "day": {
      "type": "categorical",
      "description": "Day of week to send campaign",
      "features": {
        "day_code": {
          "type": "categorical",
          "description": "Day abbreviation",
          "values": ["MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN"],
          "labels": {
            "MON": "DW001 - Monday",
            "TUE": "DW002 - Tuesday",
            "WED": "DW003 - Wednesday",
            "THU": "DW004 - Thursday",
            "FRI": "DW005 - Friday",
            "SAT": "DW006 - Saturday",
            "SUN": "DW007 - Sunday"
          }
        },
        "day_type": {
          "type": "categorical",
          "description": "Weekday vs weekend classification",
          "values": ["weekday", "weekend"],
          "labels": {
            "weekday": "Weekday (Mon-Fri)",
            "weekend": "Weekend (Sat-Sun)"
          }
        },
        "day_index": {
          "type": "numeric",
          "description": "Numeric day index for calculations",
          "values": [0, 1, 2, 3, 4, 5, 6],
          "unit": "index"
        }
      }
    },
    "offer": {
      "type": "categorical",
      "description": "Loan offer variant presented to user",
      "features": {
        "offer_type": {
          "type": "categorical",
          "description": "Type of offer value",
          "values": ["percentage", "fixed_value", "voucher"],
          "labels": {
            "percentage": "Percentage discount",
            "fixed_value": "Fixed rupee value",
            "voucher": "Partner voucher"
          }
        },
        "offer_value": {
          "type": "numeric",
          "description": "Numeric value of offer",
          "values": [10, 12000, 1500],
          "unit": "mixed",
          "labels": {
            "10": "OF001 - 10% Cashback",
            "12000": "OF002 - ₹12,000 Zero Fee",
            "1500": "OF003 - ₹1,500 Amazon Voucher"
          }
        },
        "offer_valid_days": {
          "type": "numeric",
          "description": "Days the offer is valid",
          "values": [30, 45, 60],
          "unit": "days"
        }
      }
    },
    "creative": {
      "type": "categorical",
      "description": "Campaign creative/message format",
      "features": {
        "creative_type": {
          "type": "categorical",
          "description": "Format of creative content",
          "values": ["text", "image", "carousel"],
          "labels": {
            "text": "CR001 - Text-only",
            "image": "CR002 - Image with text",
            "carousel": "CR003 - Multi-slide carousel"
          }
        },
        "creative_id": {
          "type": "categorical",
          "description": "Specific creative variant",
          "values": ["CR001", "CR002", "CR003"],
          "labels": {
            "CR001": "Card Promo #1 (Text)",
            "CR002": "Card Promo #2 (Image)",
            "CR003": "Holiday Special (Carousel)"
          }
        },
        "creative_complexity": {
          "type": "categorical",
          "description": "Complexity level of creative",
          "values": ["simple", "moderate", "complex"],
          "labels": {
            "simple": "Text only - fast load",
            "moderate": "Text + image - medium load",
            "complex": "Carousel - slow load"
          }
        }
      }
    },
    "time": {
      "type": "categorical",
      "description": "Time of day to send campaign",
      "features": {
        "time_context": {
          "type": "categorical",
          "description": "Contextual time period",
          "values": ["morning", "lunch", "evening", "weekend_morning", "night"],
          "labels": {
            "morning": "TM001 - Morning Commute (8-10 AM)",
            "lunch": "TM002 - Lunch Break (12-2 PM)",
            "evening": "TM003 - Evening Relax (7-9 PM)",
            "weekend_morning": "TM004 - Weekend Morning (9-11 AM)",
            "night": "TM005 - Late Night (9-11 PM)"
          }
        },
        "hours": {
          "type": "numeric",
          "description": "Hour of day (24-hour format)",
          "values": [8, 12, 19, 9, 21],
          "unit": "hour",
          "notes": "morning=8, lunch=12, evening=19, weekend_morning=9, night=21"
        },
        "hour_range": {
          "type": "categorical",
          "description": "Range of hours for flexibility",
          "values": ["8-10", "12-14", "19-21", "9-11", "21-23"],
          "unit": "hours"
        }
      }
    }
  }
}